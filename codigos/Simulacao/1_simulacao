library(dplyr)
library(truncnorm)

# Função para calcular a média e o desvio padrão por ano
calculate_stats_by_year <- function(df) {
  stats_by_year <- df %>%
    group_by(Ano) %>%
    filter(IDADEMAE >= 15 & IDADEMAE < 50 & !is.na(IDADEMAE), IDADEPAI >= 15 & IDADEPAI < 60 & !is.na(IDADEPAI))%>%
    summarise(
      mean_mae = mean(IDADEMAE, na.rm = TRUE),
      sd_mae = sd(IDADEMAE, na.rm = TRUE),
      mean_pai = mean(IDADEPAI, na.rm = TRUE),
      sd_pai = sd(IDADEPAI, na.rm = TRUE),
      n = n()  # Número de registros para o ano
    )
  return(stats_by_year)
}


# Função para gerar dados simulados para cada ano
create_data_by_year <- function(df, stats_by_year) {
  # Gerar os dados simulados para cada ano
  simulated_data_list <- lapply(1:nrow(stats_by_year), function(i) {
    # Obter as estatísticas para o ano
    year_stats <- stats_by_year[i, ]
    
    # Gerar idades da mãe (número de registros do ano)
    idade_mae <- round(rtruncnorm(year_stats$n, a = 15, b = 49, mean = year_stats$mean_mae, sd = year_stats$sd_mae))
    # Gerar idades do pai (número de registros do ano)
    IDADEPAI <- round(rtruncnorm(year_stats$n, a = 15, b = 59, mean = year_stats$mean_pai, sd = year_stats$sd_pai))
    print("Ano ", year_stats, "registros pai ", year_stats$n)
    # Criar um dataframe para esse ano
    data.frame(Ano = rep(year_stats$Ano, year_stats$n), idade_mae = idade_mae, IDADEPAI = IDADEPAI)
  })
  
  # Combinar os dataframes de todos os anos em um único dataframe
  dado_completo <- do.call(rbind, simulated_data_list)
  
  return(dado_completo)
}

# Função para calcular a distribuição real de pais por idade
calculate_real_distribution <- function(df) {
  real_distribution <- df %>%
  filter(IDADEPAI >= 15 & IDADEPAI < 60 & !is.na(IDADEPAI))%>%
    group_by(Ano, IDADEPAI) %>%
    summarise(total_pais = n()) %>%
    ungroup()
  
  return(real_distribution)
}

# Função para calcular a diferença percentual
calculate_percentage_difference <- function(real_data, simulated_data) {
  combined_data <- real_data %>%
    left_join(simulated_data, by = c("Ano", "IDADEPAI")) %>%
    mutate(
      total_simulado = ifelse(is.na(total_pais_simulado), 0, total_pais_simulado),
      diff_percentual = 100 * (total_simulado - total_pais) / total_pais
    )
  
  return(combined_data)
}

# Passo 1: Calcular as estatísticas por ano
stats_by_year <- calculate_stats_by_year(uf)

# Passo 2: Gerar dados simulados com base nas estatísticas de cada ano
dado_simulado <- create_data_by_year(uf, stats_by_year)

# Passo 3: Calcular a distribuição real de pais por idade
real_distribution <- calculate_real_distribution(uf)

# Passo 4: Calcular a distribuição simulada de pais por idade
simulated_distribution <- dado_simulado %>%
  group_by(Ano, IDADEPAI) %>%
  summarise(total_pais_simulado = n()) %>%
  ungroup()

# Passo 5: Calcular a diferença percentual entre a distribuição real e simulada
result <- calculate_percentage_difference(real_distribution, simulated_distribution)

# Visualizar o resultado final
glimpse(result)
View(result)



