# Função para preparar os dados
uf_prepare <- function(df) {
  dist_complete_case <- df %>%
    select(Ano, IDADEPAI) %>%  # Seleciona as colunas Ano e IDADEPAI
    filter(IDADEPAI >= 15 & IDADEPAI <= 59) %>%  # Filtra para idades de pais entre 15 e 59
    group_by(Ano, IDADEPAI) %>%  # Agrupa por Ano e IDADEPAI
    summarise(total_pais = n(), .groups = "drop")  # Conta o número de pais para cada combinação
  
  # Criando uma lista onde cada ano é um índice
  dist_by_year <- dist_complete_case %>%
    split(.$Ano) %>%  # Divide por Ano
    lapply(function(x) {
      # Retorna um data frame com idade do pai e total de pais
      data.frame(idade_pai = x$IDADEPAI, total_pais = x$total_pais)
    })
  
  return(dist_by_year)
}

