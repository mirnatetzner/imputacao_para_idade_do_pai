# Valores para geração do dataset a partir da regressão
# (modela a relação linear entre idade da mae e do pai)

uf$IDADEMAE <- as.numeric(as.character(uf$IDADEMAE))
uf$IDADEPAI <- as.numeric(as.character(uf$IDADEPAI))


modelo <- lm(IDADEPAI ~ IDADEMAE, data = uf)

beta <- coef(modelo)[2]  # Coeficiente de regressão (inclinação)
sigma2 <- sum(residuals(modelo)^2) / modelo$df.residual # Variância dos resíduos (erro)
#residuos <- residuals(modelo)  # Obtendo os resíduos


imp.reg.lin.esto <- function(beta, sigma2, df, run = 2) {
  set.seed(12345 + run)  # Permite variação entre diferentes execuções
  
  # Filtra os casos onde a idade do pai está ausente
  df_missing <- df %>% filter(is.na(IDADEPAI))

  # Se não houver valores faltantes, retorna a base original sem mudanças
  if (nrow(df_missing) == 0) {
    return(df)
  }
  
  # Pega as idades da mãe correspondentes
  idade_mae <- df_missing$IDADEMAE

  # Gerando o erro aleatório a partir da variância residual do modelo
  erro <- rnorm(length(idade_mae), mean = 0, sd = sqrt(sigma2))

  # Calculando a idade do pai imputada
  idade_pai_imputada <- round(beta * idade_mae + erro)

  # Garantindo que idade_pai esteja dentro dos limites (15 a 59 anos)
  idade_pai_imputada <- pmax(pmin(idade_pai_imputada, 59), 15)

  # Inserindo os valores imputados na base original
  df$IDADEPAI[is.na(df$IDADEPAI)] <- idade_pai_imputada

  return(df)
}

