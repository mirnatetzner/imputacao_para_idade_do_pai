create.data <- function(beta, sigma2, n = 5, run = 2) {
  set.seed(12345 + run)  # Permite variação entre diferentes execuções
  
  # Gerando idade da mãe entre 15 e 49 anos
  x <- round(rtruncnorm(n, a = 15, b = 49, mean = mean_mae, sd = sd_mae))
  
  # Gerando idade do pai entre 15 e 59 anos
  y <- round(rtruncnorm(n, a = 15, b = 59, mean = mean_pai, sd = sd_pai))
  
  data.frame(idade_mae = x, idade_pai = y)
}


