library(dplyr)
pacotes <- c("microdatasus", "mice", "stringr", "ggmice", "lubridate", "readxl",
"hms", "naniar", "future.apply", "data.table", "boot",
"tidyverse", "ggplot2", "writexl", "Amelia", "openxlsx", "extrafont","rlang")
pacotes %>% purrr::walk(~ { if (!require(.x, character.only = TRUE)) install.packages(.x) })
indicadores
View(indicadores)
library(dplyr)
library(ggplot2)
library(ggh4x)
# Mantém todos os métodos e classifica em tipo
pb_filtrados <- indicadores %>%
mutate(
tipo_metodo = case_when(
metodo %in% c("Análise de casos completos", "Média", "Mediana") ~ "Simples",
TRUE ~ "Condicional"
)
)
# Lista de proporções
proporcoes <- unique(pb_filtrados$proporcao)
# Loop para cada proporção
for (p in proporcoes) {
dados_p <- pb_filtrados %>% filter(proporcao == p)
grafico <- ggplot(dados_p, aes(x = Grupo_idade, y = PB_TEFM, color = metodo, linetype = metodo, group = metodo)) +
geom_line(size = 1) +
geom_point() +
ggh4x::facet_wrap2(~ mecanismo, ncol = 1, scales = "free_y", strip.position = "top", axes = "all") +
labs(
title = "",
x = "Grupo de Idade",
y = "Viés relativo TEFM",
color = "Método",
linetype = "Método"
) +
theme_minimal() +
theme(
legend.position = "bottom",
strip.placement = "outside",
axis.text.x = element_text(angle = 45, hjust = 1),
strip.background = element_blank(),
panel.spacing = unit(1, "lines")
) +
guides(color = guide_legend(ncol = 3), linetype = guide_legend(ncol = 3)) +
scale_linetype_manual(
values = c(
"Análise de casos completos" = "dashed",
"Média" = "dotdash",
"Mediana" = "twodash",
"MCIM" = "solid",
"MCIM e ao \nestado civil" = "solid"
# Adicione outros métodos conforme necessário
)
)
# Nome do arquivo
nome_arquivo <- paste0("PB_tefm_", gsub("%", "pct", p), ".pdf")
ggsave(nome_arquivo, plot = grafico, width = 6, height = 10, dpi = 300)
}
head(dados_p)
library(dplyr)
library(ggplot2)
library(ggh4x)
# Classificar os métodos simples
pb_filtrados <- indicadores %>%
mutate(
tipo_metodo = case_when(
metodo %in% c("Análise de casos completos", "Média", "Mediana") ~ "Simples",
TRUE ~ "Condicional"
),
Grupo_idade = factor(Grupo_idade, levels = unique(Grupo_idade))
)
proporcoes <- unique(pb_filtrados$proporcao)
for (p in proporcoes) {
dados_p <- pb_filtrados %>% filter(proporcao == p)
grafico <- ggplot(dados_p, aes(x = Grupo_idade, y = PB_TEFM,
color = metodo,
linetype = metodo,
group = interaction(metodo, mecanismo))) +
geom_line(size = 0.9) +
geom_point(size = 1.8) +
ggh4x::facet_wrap2(~ mecanismo, ncol = 1, scales = "free_y",
strip.position = "top", axes = "all") +
labs(
x = "Grupo de Idade",
y = "Viés relativo TEFM",
color = "Método",
linetype = "Método"
) +
theme_minimal() +
theme(
legend.position = "bottom",
legend.title = element_text(size = 11, face = "bold"),
legend.text = element_text(size = 10),
strip.placement = "outside",
axis.text.x = element_text(angle = 45, hjust = 1),
axis.title = element_text(size = 12, face = "bold"),
strip.background = element_blank(),
panel.spacing = unit(1, "lines")
) +
guides(color = guide_legend(ncol = 3), linetype = guide_legend(ncol = 3)) +
scale_linetype_manual(
values = c(
"Análise de casos completos" = "dashed",
"Média" = "dotdash",
"Mediana" = "twodash",
"MCIM" = "solid",
"MCIM e ao \nestado civil" = "solid"
)
)
nome_arquivo <- paste0("PB_tefm_", gsub("%", "pct", p), ".pdf")
ggsave(nome_arquivo, plot = grafico, width = 6, height = 10, dpi = 300)
}
unique(indicadores$metodo)
# Vetor de cores personalizadas por método
cores_metodos <- c(
