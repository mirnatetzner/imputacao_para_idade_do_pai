library(ggplot2)
library(dplyr)
library(ggh4x)
# Filtra dados e remove métodos simples
pb_filtrados <- indicadores
# %>%   filter(!metodo %in% c("Análise de casos completos", "Média", "Mediana"))
# Calcula o valor máximo global de PB_TEFM
y_max_global <- max(pb_filtrados$PB_TEFM, na.rm = TRUE)
# Lista de proporções
proporcoes <- unique(pb_filtrados$proporcao)
# Loop para cada proporção
for (p in proporcoes) {
dados_p <- pb_filtrados %>% filter(proporcao == p)
grafico <- ggplot(dados_p, aes(x = Grupo_idade, y = PB_TEFM, color = metodo, group = metodo)) +
geom_line() +
geom_point() +
ggh4x::facet_wrap2(~ mecanismo, ncol = 1, scales = "fixed", strip.position = "top", axes = "all") +
labs(
title = paste(""),
x = "Grupo de Idade",
y = "Viés relativo TEFM",
color = "Método"
) +
theme_minimal() +
theme(
legend.position = "bottom",
strip.placement = "outside",
axis.text.x = element_text(angle = 45, hjust = 1),
strip.background = element_blank(),
panel.spacing = unit(1, "lines")
)+guides(color = guide_legend(ncol = 2))+
coord_cartesian(ylim = c(0, y_max_global))  # usa o máximo global
# Nome do arquivo
nome_arquivo <- paste0("PB_tefm_", gsub("%", "pct", p), ".pdf")
ggsave(nome_arquivo, plot = grafico, width = 6, height = 10, dpi = 300)
}
