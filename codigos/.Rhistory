)
# Criar arquivo PNG
png(nome_arquivo, width = 800, height = 800, res = 100)
# Criar gráfico de radar apenas para o indicador específico
dados <- df_transposto[c("max", "min", indicador), ]
radarchart(
dados,
axistype = 1,
pcol = rainbow(ncol(dados)),  # Diferentes cores para as CAPs
plwd = 2,
plty = 1,
cglcol = "grey",
cglty = 1,
cglwd = 0.8,
axislabcol = "black",
vlcex = 1,
caxislabels = axis_labels  # Define os novos rótulos personalizados
)
# Adicionar título
mtext(
paste("Radar -", indicador),
side = 3,
line = 2,
cex = 1.5,
font = 2,
col = "darkblue",
adj = 0.5
)
# Fechar o arquivo PNG
dev.off()
}
cat("Gráficos salvos como PNG.\n")
# Transpor a tabela: CAPs viram colunas e indicadores viram linhas
criterios_gerais_renda_CAP_rounded <- as.data.frame(lapply(criterios_gerais_renda_CAP, round, digits = 2))
df_transposto <- as.data.frame(t(criterios_gerais_renda_CAP_rounded))
