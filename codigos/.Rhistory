tftf_todos
library(dplyr)
library(ggplot2)
# Juntar as tabelas
tft_merged <- left_join(tftm_tabela_larga, tftf_todos, by = "UF") %>%
mutate(
TFTM = as.numeric(gsub(",", ".", TFTM)),
TFTF = as.numeric(gsub(",", ".", TFTF))
)
# Plotar
ggplot(tft_merged, aes(x = TFTM, y = TFTF, label = UF)) +
geom_point(size = 3, color = "steelblue") +
geom_text(vjust = -0.8, size = 3.5) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "gray40") +
labs(
x = "Taxa de Fecundidade Total Masculina (TFTM)",
y = "Taxa de Fecundidade Total Feminina (TFTF)",
title = "Comparação entre TFTM e TFTF por UF"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
axis.title = element_text(face = "bold", size = 12),
axis.text = element_text(size = 11)
)
