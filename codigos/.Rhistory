tft <- fluxo_um_resultados_regioes[[reg]]$tft
tibble(
UF = reg,
TFTM = tft
)
})
# Adiciona o Brasil
fluxo_um_tefm_br$UF <- "BR"
tefm_regioes <- bind_rows(tefm_regioes, fluxo_um_tefm_br)
fluxo_um_tftm_brasil$UF <- "BR"
# Criar tibble
tftm_brasil <- tibble(
UF = fluxo_um_tftm_brasil$UF,
TFTM = fluxo_um_tftm_brasil[[1]]
)
tftm_regioes <- bind_rows(tftm_regioes, tftm_brasil)
# Dados dos estados
tefm_estados <- map_dfr(UFs, function(uf) {
df <- get(paste0("tefm_", uf))
df$UF <- uf
df
})
tftm_estados <- map_dfr(UFs, function(uf) {
df <- get(paste0("tftm_", uf))
valor = df
tibble(
UF  = uf,
TFTM = valor
)})
tefm_todos <- bind_rows(tefm_estados, tefm_regioes)
tftm_todos <- bind_rows(tftm_estados, tftm_regioes)
ordem_final <- c(
"BR", "NO", "ND", "SD", "SU", "CO",  # Regiões
"RO", "AC", "AM", "RR", "PA", "AP", "TO",  # Norte
"MA", "PI", "CE", "RN", "PB", "PE", "AL", "SE", "BA",  # Nordeste
"MG", "ES", "RJ", "SP",  # Sudeste
"PR", "SC", "RS",  # Sul
"MS", "MT", "GO", "DF"   # Centro-Oeste
)
tefm_tabela_larga <- tefm_todos %>%
select(-nascimentos, -Populacao) %>%
mutate(
UF = factor(UF, levels = ordem_final),
#TEFM = as.numeric(sub(",", ".", TEFM))  # converte para número real
) %>%
pivot_wider(
names_from = Grupo_idade,
values_from = TEFM  # move os valores de TEFM para as colunas
) %>%
arrange(UF)
tftm_tabela_larga <- tftm_todos %>%
mutate(
UF = factor(UF, levels = ordem_final),
) %>%
arrange(UF)
