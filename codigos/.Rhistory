# Converter todas as colunas para numérico
df_transposto[] <- lapply(df_transposto, as.numeric)
# Adicionar as linhas de referência (máximo e mínimo) com nomes corretos
max_values <- apply(df_transposto, 2, max, na.rm = TRUE)  # Máximos
min_values <- apply(df_transposto, 2, min, na.rm = TRUE)  # Mínimos
df_transposto <- rbind(
"max" = max_values,
"min" = min_values,
df_transposto
)
# Criar gráficos de radar para cada indicador
indicadores <- rownames(df_transposto)[-c(1, 2)]  # Ignorar linhas de máximo e mínimo
for (indicador in indicadores) {
nome_arquivo <- paste0("grafico_radar_", indicador, ".png")
axis_labels <- seq(
min(df_transposto[indicador, ], na.rm = TRUE),
max(df_transposto[indicador, ], na.rm = TRUE),
length.out = 6
)
# Criar arquivo PNG
png(nome_arquivo, width = 800, height = 800, res = 100)
# Criar gráfico de radar apenas para o indicador específico
dados <- df_transposto[c("max", "min", indicador), ]
radarchart(
dados,
axistype = 1,
pcol = rainbow(ncol(dados)),  # Diferentes cores para as CAPs
plwd = 2,
plty = 1,
cglcol = "grey",
cglty = 1,
cglwd = 0.8,
axislabcol = "black",
vlcex = 1,
caxislabels = axis_labels  # Define os novos rótulos personalizados
)
# Adicionar título
mtext(
paste("Radar -", indicador),
side = 3,
line = 2,
cex = 1.5,
font = 2,
col = "darkblue",
adj = 0.5
)
# Fechar o arquivo PNG
dev.off()
}
